# Root .gitignore
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment files
.env
.env.local
backend/.env
frontend/.env.local

# Build artifacts
dist/
build/
.vite/

# Large Media Files (Too big for GitHub)
*.mp4
*.mov
*.mkv
*.avi
*.wmv
*.flv
frontend/public/videos/
assets/videos/

# Keep static images if requested, but ignore large ones
# frontend/public/images/ (uncomment if you want to ignore all images too)

# System files
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
